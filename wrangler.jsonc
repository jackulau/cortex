{
  "name": "cortex",
  "main": "src/server.ts",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],

  // Tail Worker — forwards error logs to Discord alerts
  "tail_consumers": [{ "service": "cortex-tail-worker" }],

  // Durable Objects
  "durable_objects": {
    "bindings": [
      {
        "name": "CortexAgent",
        "class_name": "CortexAgent"
      },
      {
        "name": "WatchScheduler",
        "class_name": "WatchSchedulerDO"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CortexAgent"]
    },
    {
      "tag": "v2",
      "new_classes": ["WatchSchedulerDO"]
    }
  ],

  // D1 Database
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cortex-db",
      "database_id": "2839c0c7-d433-4ce5-9e06-6f7cbee18528"
    }
  ],

  // R2 Storage — lifecycle policies configured via scripts/setup-r2-lifecycle.sh:
  //   - exports/      -> expire after 30 days
  //   - screenshots/  -> expire after 14 days
  //   - archives/     -> expire after 90 days
  // Event notifications configured via Cloudflare API/Dashboard:
  //   - Trigger: object-create events (PutObject, CopyObject, CompleteMultipartUpload)
  //   - Prefix filter: "exports/"
  //   - Destination: cortex-r2-events queue
  //   - Setup script: scripts/r2-event-notifications.sh
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "cortex-storage"
    }
  ],

  // Workers AI — routed through AI Gateway for caching, logging, and observability
  "ai": {
    "binding": "AI",
    "gateway": {
      "id": "cortex-gateway"
    }
  },

  // Browser Rendering — moved to isolated crawler worker (cortex-crawler)
  // Main worker no longer needs BROWSER binding; crawl requests are forwarded
  // via the CRAWLER_SERVICE service binding.

  // Service Bindings — isolated crawler worker
  "services": [
    {
      "binding": "CRAWLER_SERVICE",
      "service": "cortex-crawler"
    }
  ],

  // Workflows — durable multi-step pipelines
  "workflows": [
    {
      "binding": "CONSOLIDATION_WORKFLOW",
      "name": "cortex-consolidation",
      "class_name": "ConsolidationWorkflow"
    }
  ],

  // Vectorize — semantic memory vector index
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "cortex-memories"
    }
  ],

  // KV — response and embedding cache
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "PLACEHOLDER_CACHE_KV_ID"
    }
  ],

  // Queues — async crawl, consolidation, and R2 event pipelines
  "queues": {
    "producers": [
      {
        "binding": "CRAWL_QUEUE",
        "queue": "cortex-crawl"
      },
      {
        "binding": "CONSOLIDATION_QUEUE",
        "queue": "cortex-consolidate"
      },
      {
        "binding": "R2_EVENT_QUEUE",
        "queue": "cortex-r2-events"
      }
    ],
    "consumers": [
      {
        "queue": "cortex-crawl",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "cortex-consolidate",
        "max_batch_size": 5,
        "max_batch_timeout": 60
      },
      {
        "queue": "cortex-r2-events",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      }
    ]
  },

  // Analytics Engine — event tracking
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "cortex_events"
    }
  ],

  // Rate Limiting
  "unsafe": {
    "bindings": [
      {
        "type": "ratelimit",
        "name": "RATE_LIMITER",
        "namespace_id": "cortex-rl",
        "simple": {
          "limit": 100,
          "period": 60
        }
      }
    ]
  },

  // Cron triggers — 6-hour crawler cron removed in favor of per-item DO alarms.
  // Retained: daily digest at 9am UTC.
  "triggers": {
    "crons": ["0 9 * * *"]
  },

  // Environment variables
  "vars": {
    "EMBEDDING_MODEL": "@cf/baai/bge-large-en-v1.5",
    "CHAT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    // Model tier overrides (optional — model-router defaults to the models below)
    // "AI_MODEL_HEAVY": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    // "AI_MODEL_LIGHT": "@cf/meta/llama-3.1-8b-instruct-fp8",
    // Claude API — external provider for chat and consolidation (higher quality)
    // ANTHROPIC_API_KEY: set via `wrangler secret put ANTHROPIC_API_KEY` — do NOT commit
    "CLAUDE_MODEL": "claude-sonnet-4-6",
    // API_KEY: set via `wrangler secret put API_KEY` — do NOT commit real keys
    "API_KEY": "",
    // ALLOWED_ORIGINS: comma-separated list of allowed CORS origins
    "ALLOWED_ORIGINS": "https://cortex.example.com",
    // DISCORD_DIGEST_CHANNEL_ID: set via `wrangler secret put DISCORD_DIGEST_CHANNEL_ID`
    // or set here for non-secret channel IDs
    "DISCORD_DIGEST_CHANNEL_ID": "",
    // Cloudflare Access Zero Trust auth
    // CF_ACCESS_AUD: Application Audience (AUD) tag from Access dashboard
    "CF_ACCESS_AUD": "",
    // CF_ACCESS_TEAM_DOMAIN: your Zero Trust team domain (e.g. "myteam" for myteam.cloudflareaccess.com)
    "CF_ACCESS_TEAM_DOMAIN": ""
  }
}
